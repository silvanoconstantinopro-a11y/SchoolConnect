generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum Perfil {
  ADMIN
  PROFESSOR
  ENCARREGADO
}

enum Relacao {
  PAI
  MAE
  TUTOR
}

// =========================
// USUÁRIO
// =========================

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  telefone  String   @unique
  perfil    Perfil
  imagem    String?

  criadoEm  DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  relacaoEducando   Relacao?
  codigoVerificacao String?

  // RELAÇÕES
  alunos             Aluno[]               @relation("EncarregadoAlunos")
  turmas             Turma[]
  disciplinas        Disciplina[]          @relation("ProfessorDisciplinas")
  cursos             Curso[]               @relation("ProfessorCursos")
  mensagensEnviadas  Mensagem[]            @relation("Remetente")
  mensagensRecebidas Mensagem[]            @relation("Destinatario")
  reunioes           ReuniaoParticipante[]
  reunioesAgendadas  Reuniao[]
  codigoProfessor    CodigoProfessor?

  @@map("usuarios")
}

// =========================
// ALUNO
// =========================

model Aluno {
  id        Int    @id @default(autoincrement())
  nome      String
  matricula String @unique
  telefone  String @unique
  imagem    String?
  classe    String

  turmaId       Int
  encarregadoId Int?
  cursoId       Int

  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  turma       Turma    @relation(fields: [turmaId], references: [id])
  encarregado Usuario? @relation("EncarregadoAlunos", fields: [encarregadoId], references: [id])
  curso       Curso    @relation(fields: [cursoId], references: [id])
  notas       Nota[]

  @@map("alunos")
}

// =========================
// TURMA
// =========================

model Turma {
  id   Int    @id @default(autoincrement())
  nome String

  professorId Int?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  professor Usuario? @relation(fields: [professorId], references: [id])
  alunos    Aluno[]

  @@map("turmas")
}

// =========================
// DISCIPLINA
// =========================

model Disciplina {
  id        Int    @id @default(autoincrement())
  nome      String
  descricao String
  cursoId   Int

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  curso       Curso     @relation(fields: [cursoId], references: [id])
  professores Usuario[] @relation("ProfessorDisciplinas")
  notas       Nota[]

  @@map("disciplinas")
}

// =========================
// NOTAS
// =========================

model Nota {
  id    Int   @id @default(autoincrement())
  valor Float
  tipo  String

  alunoId      Int
  disciplinaId Int

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  aluno      Aluno      @relation(fields: [alunoId], references: [id])
  disciplina Disciplina @relation(fields: [disciplinaId], references: [id])

  @@map("notas")
}

// =========================
// MENSAGENS
// =========================

model Mensagem {
  id       Int    @id @default(autoincrement())
  conteudo String

  remetenteId    Int
  destinatarioId Int

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
  editadoEm    DateTime?

  deletadoParaRemetente    Boolean @default(false)
  deletadoParaDestinatario Boolean @default(false)

  arquivoUrl      String?
  arquivoNome     String?
  arquivoTipo     String?
  arquivoTamanho  Int?

  remetente    Usuario @relation("Remetente", fields: [remetenteId], references: [id])
  destinatario Usuario @relation("Destinatario", fields: [destinatarioId], references: [id])

  @@map("mensagens")
}

// =========================
// AVISOS
// =========================

model Aviso {
  id        Int    @id @default(autoincrement())
  titulo    String
  conteudo  String
  imagem    String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("avisos")
}

// =========================
// RELATÓRIO
// =========================

model Relatorio {
  id       Int    @id @default(autoincrement())
  titulo   String
  conteudo String

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("relatorios")
}

// =========================
// EVENTO
// =========================

model Evento {
  id        Int    @id @default(autoincrement())
  titulo    String
  descricao String
  imagem    String?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("eventos")
}

// =========================
// REUNIÃO
// =========================

model Reuniao {
  id          Int      @id @default(autoincrement())
  titulo      String
  local       String
  linkMeeting String?
  dataHora    DateTime?

  criadoPorId Int?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  criadoPor     Usuario?              @relation(fields: [criadoPorId], references: [id])
  participantes ReuniaoParticipante[]

  @@map("reunioes")
}

// =========================
// CURSO
// =========================

model Curso {
  id        Int    @id @default(autoincrement())
  nome      String
  descricao String

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  disciplinas Disciplina[]
  alunos      Aluno[]
  professores Usuario[] @relation("ProfessorCursos")

  @@map("cursos")
}

// =========================
// PARTICIPANTES REUNIÃO
// =========================

model ReuniaoParticipante {
  id        Int @id @default(autoincrement())
  reuniaoId Int
  usuarioId Int

  reuniao Reuniao @relation(fields: [reuniaoId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@unique([reuniaoId, usuarioId])
  @@map("reuniao_participantes")
}

// =========================
// FEEDBACK
// =========================

model Feedback {
  id       Int    @id @default(autoincrement())
  nome     String
  email    String
  assunto  String
  mensagem String

  criadoEm DateTime @default(now())

  @@map("feedbacks")
}

// =========================
// CÓDIGO PROFESSOR
// =========================

model CodigoProfessor {
  id     Int    @id @default(autoincrement())
  codigo String @unique
  usado  Boolean @default(false)

  professorId Int? @unique

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  professor Usuario? @relation(fields: [professorId], references: [id])

  @@map("codigos_professor")
}
