// SchoolConnect Database Schema v2.0
// Versão simplificada e estável para SQLite

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ============================================================
// ENUMS
// ============================================================
enum PerfilUsuario {
  ADMIN
  PROFESSOR
  ENCARREGADO
}

enum RelacaoEducando {
  PAI
  MAE
  TUTOR
}

// ============================================================
// MODELOS PRINCIPAIS
// ============================================================

model Usuario {
  id                Int               @id @default(autoincrement())
  nome              String
  email             String            @unique
  senha             String
  telefone          String
  perfil            PerfilUsuario
  imagem            String?
  relacaoEducando   RelacaoEducando?
  codigoVerificacao String?           @unique
  
  criadoEm          DateTime          @default(now())
  atualizadoEm      DateTime          @updatedAt
  
  @@map("usuarios")
  @@index([email])
  @@index([perfil])
  @@index([telefone])
}

model Aluno {
  id            Int               @id @default(autoincrement())
  nome          String
  matricula     String            @unique
  telefone      String?
  classe        String?
  imagem        String?
  turmaId       Int
  cursoId       Int
  encarregadoId Int?
  
  criadoEm      DateTime          @default(now())
  atualizadoEm  DateTime          @updatedAt
  
  @@map("alunos")
  @@index([matricula])
  @@index([turmaId])
  @@index([cursoId])
  @@index([encarregadoId])
}

model Turma {
  id          Int         @id @default(autoincrement())
  nome        String      @unique
  professorId Int?
  
  criadoEm    DateTime    @default(now())
  atualizadoEm DateTime   @updatedAt
  
  @@map("turmas")
  @@index([professorId])
}

model Curso {
  id          Int          @id @default(autoincrement())
  nome        String       @unique
  descricao   String
  
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime    @updatedAt
  
  @@map("cursos")
}

model Disciplina {
  id          Int          @id @default(autoincrement())
  nome        String
  descricao   String?
  cursoId     Int
  
  criadoEm    DateTime     @default(now())
  atualizadoEm DateTime    @updatedAt
  
  @@unique([nome, cursoId])
  @@index([cursoId])
  @@map("disciplinas")
}

model Nota {
  id           Int       @id @default(autoincrement())
  valor        Float
  tipo         String
  alunoId      Int
  disciplinaId Int
  
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  
  @@unique([alunoId, disciplinaId, tipo])
  @@index([alunoId])
  @@index([disciplinaId])
  @@map("notas")
}

model Mensagem {
  id                     Int       @id @default(autoincrement())
  conteudo               String
  remetenteId            Int
  destinatarioId         Int
  
  arquivoUrl             String?
  arquivoNome            String?
  arquivoTipo            String?
  arquivoTamanho         Int?
  
  editadoEm              DateTime?
  deletadoParaRemetente  Boolean   @default(false)
  deletadoParaDestinatario Boolean  @default(false)
  
  criadoEm               DateTime  @default(now())
  
  @@index([remetenteId])
  @@index([destinatarioId])
  @@index([criadoEm])
  @@map("mensagens")
}

model Aviso {
  id        Int       @id @default(autoincrement())
  titulo    String
  conteudo  String
  imagem    String?
  
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  
  @@index([criadoEm])
  @@map("avisos")
}

model Evento {
  id        Int       @id @default(autoincrement())
  titulo    String
  descricao String
  imagem    String?
  
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  
  @@index([criadoEm])
  @@map("eventos")
}

model Reuniao {
  id           Int       @id @default(autoincrement())
  titulo       String
  local        String
  linkMeeting  String?
  dataHora     DateTime?
  criadoPorId  Int?
  
  criadoEm     DateTime  @default(now())
  atualizadoEm DateTime  @updatedAt
  
  @@index([dataHora])
  @@index([criadoPorId])
  @@map("reunioes")
}

model ReuniaoParticipante {
  id          Int      @id @default(autoincrement())
  reuniaoId   Int
  usuarioId   Int
  
  @@unique([reuniaoId, usuarioId])
  @@map("reuniao_participantes")
}

model Relatorio {
  id        Int       @id @default(autoincrement())
  titulo    String
  conteudo  String
  
  criadoEm  DateTime  @default(now())
  atualizadoEm DateTime @updatedAt
  
  @@index([criadoEm])
  @@map("relatorios")
}

model Feedback {
  id        Int       @id @default(autoincrement())
  nome      String
  email     String
  assunto   String
  mensagem  String
  
  criadoEm  DateTime  @default(now())
  
  @@index([criadoEm])
  @@index([email])
  @@map("feedbacks")
}

model CodigoProfessor {
  id          Int       @id @default(autoincrement())
  codigo      String    @unique
  usado       Boolean   @default(false)
  professorId Int?      @unique
  
  criadoEm    DateTime  @default(now())
  
  @@index([codigo])
  @@index([usado])
  @@map("codigos_professor")
}