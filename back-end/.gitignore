# Servidor
NODE_ENV=development
PORT=3000

# Banco de dados
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=seu-jwt-secret-aqui-mude-em-producao
JWT_EXPIRATION=24h

# CORS
CORS_ORIGIN=http://localhost:3000,https://schoolconnect.onrender.com

# Admin
ADMIN_USER=admin
ADMIN_SENHA=schoolconnect2026
ADMIN_EMAIL=admin@schoolconnect.com

# Uploads
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# WebSocket
WS_HEARTBEAT_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100