{
  "name": "schoolconnect-backend",
  "version": "2.0.0",
  "description": "Sistema de gestão escolar - Backend",
  "type": "module",
  "main": "servidor.js",
  "scripts": {
    "start": "node servidor.js",
    "dev": "nodemon servidor.js",
    "build": "npm run prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:baseline": "node scripts/migrate.js",
    "test": "NODE_ENV=test node --test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.22.0",
    "sqlite3": "^5.1.6",
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "prettier": "^3.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}